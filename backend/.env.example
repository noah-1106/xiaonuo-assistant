# 小诺智能助理 - 后端环境变量示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 服务器配置
# ============================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ============================================
# 数据库配置
# ============================================
# 方式1：使用 MongoDB URI（推荐）
MONGO_URI=mongodb://localhost:27017/xiaonuo

# 方式2：使用分散配置
DB_HOST=localhost
DB_PORT=27017
DB_NAME=xiaonuo
DB_USER=
DB_PASSWORD=

# ============================================
# JWT配置
# ============================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# ============================================
# CORS配置
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# 火山方舟AI配置
# ============================================
ARK_API_KEY=your-ark-api-key-here
AI_MODEL=doubao-seed-1-8-251228
AI_MODEL_ID=doubao-seed-1-8-251228
AI_ENDPOINT_ID=your-endpoint-id-here
AI_TEMPERATURE=0.8
AI_TOP_P=0.95
AI_USE_CONTEXT_CACHE=true

# ============================================
# 火山方舟TOS配置
# ============================================
TOS_ENDPOINT=https://tos-cn-beijing.volces.com
TOS_ACCESS_KEY_ID=your-access-key-id-here
TOS_ACCESS_KEY_SECRET=your-access-key-secret-here
TOS_BUCKET=your-bucket-name
TOS_REGION=cn-beijing
TOS_FILE_PREFIX=xiaonuo/

# ============================================
# 微信支付配置
# ============================================
WECHAT_APPID=your-wechat-appid-here
WECHAT_MCHID=your-wechat-mchid-here
WECHAT_API_KEY=your-wechat-api-key-here
WECHAT_SERIAL_NO=your-wechat-serial-no-here
WECHAT_NOTIFY_URL=http://localhost:3001/api/wechat/notify
WECHAT_SANDBOX=true
WECHAT_PRIVATE_KEY_PATH=./cert/apiclient_key.pem

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
