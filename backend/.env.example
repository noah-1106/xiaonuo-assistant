# 数据库配置
DB_HOST=localhost
DB_PORT=27017
DB_NAME=xiaonuo
DB_USER=
DB_PASSWORD=

# 服务器配置
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your_secure_jwt_secret
JWT_EXPIRES_IN=7d

# AI服务配置
ARK_API_KEY=your_ark_api_key
AI_MODEL=doubao-seed-1-8-251228
AI_MODEL_ID=doubao-seed-1-8-251228
AI_ENDPOINT_ID=ep-m-20260128215950-dcxfh
AI_TEMPERATURE=0.8
AI_TOP_P=0.95
AI_USE_CONTEXT_CACHE=true

# TOS配置
TOS_ENDPOINT=https://tos-cn-beijing.volces.com
TOS_ACCESS_KEY_ID=your_tos_access_key_id
TOS_ACCESS_KEY_SECRET=your_tos_access_key_secret
TOS_BUCKET=your_tos_bucket
TOS_REGION=cn-beijing
TOS_FILE_PREFIX=xiaonuo/

# CORS配置
CORS_ORIGIN=http://localhost:5173,https://your-domain.com

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_API_KEY=your_wechat_api_key
WECHAT_SERIAL_NO=your_wechat_serial_no
WECHAT_NOTIFY_URL=https://your-domain.com/api/wechat/notify
WECHAT_SANDBOX=false
