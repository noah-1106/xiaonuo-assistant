# 小诺智能助理 - 前端环境变量示例
# 复制此文件为 .env 并填入实际值

# ============================================
# API配置
# ============================================

# 开发环境
VITE_API_BASE_URL=/api

# 生产环境示例
# VITE_API_BASE_URL=https://your-domain.com/api

# ============================================
# 应用配置
# ============================================
VITE_NODE_ENV=development
VITE_APP_NAME=小诺智能助理
VITE_APP_VERSION=1.0.0
